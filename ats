import httpClient from './httpClient';
import {
  RECORD_HEADERS,
  SELECT_RECORD_HEADERS,
} from '../constants/aprimo';
import { UpdateRecordFieldRequest } from '../models/aprimo/UpdateRecordFieldRequest';
import { AprimoRecord } from '../models/aprimo/AprimoRecord';
import config from '../config/env';
import { validateRecordId } from '../utils/recordIdValidator';
import { logAprimoRequestError } from '../utils/aprimoErrorLogger';
import { httpsAgent } from '../constants/httpAgent';
import logger from '../utils/logger';

class RecordService {
  public static async getRecordById(recordId: string): Promise<AprimoRecord> {
    const validatedRecordId = validateRecordId(recordId);

    logger.info({
      msg: 'Calling Aprimo GET record api',
      options: {
        recordId,
      },
    });

    try {
      const response = await httpClient.get<AprimoRecord>(
        `/api/core/record/${validatedRecordId}`,
        {
          headers: {
            ...RECORD_HEADERS,
          },
          httpsAgent,
        }
      );

      logger.info({
        msg: 'Aprimo GET record api completed successfully',
        options: {
          recordId,
          statusCode: response.status,
        },
      });

      return response.data;
    } catch (error) {
      logAprimoRequestError(error, 'Aprimo GET record api request failed');
      throw error;
    }
  }

  public static async getRecordWithSelectedFields(
    recordId: string,
    selectFields: string[]
  ): Promise<AprimoRecord> {
    const validatedRecordId = validateRecordId(recordId);

    logger.info({
      msg: 'Calling Aprimo GET record api with selected fields',
      options: {
        recordId,
        selectFields,
      },
    });

    try {
      const response = await httpClient.get<AprimoRecord>(
        `/api/core/record/${validatedRecordId}`,
        {
          headers: {
            ...SELECT_RECORD_HEADERS,
            'select-record-fields': selectFields.join(','),
          },
          httpsAgent,
        }
      );

      logger.info({
        msg: 'Aprimo GET record api completed successfully',
        options: {
          recordId,
          selectFields,
          statusCode: response.status,
        },
      });

      return response.data;
    } catch (error) {
      logAprimoRequestError(error, 'Aprimo get api request failed');
      throw error;
    }
  }

  public static async updateRecordField(
    recordId: string,
    fieldId: string,
    value: string
  ): Promise<AprimoRecord> {
    const validatedRecordId = validateRecordId(recordId);

    logger.info({
      msg: 'Calling Aprimo update record field api',
      options: {
        recordId,
        fieldId,
        value,
      },
    });

    try {
      const requestBody = new UpdateRecordFieldRequest(
        fieldId,
        config.APRIMO_LANGUAGE_ID,
        value
      );

      const response = await httpClient.put<AprimoRecord>(
        `/api/core/record/${validatedRecordId}`,
        requestBody,
        {
          headers: {
            ...RECORD_HEADERS,
            'Content-Type': 'application/json',
          },
          httpsAgent,
        }
      );

      logger.info({
        msg: 'Aprimo update record field API completed successfully',
        options: {
          recordId,
          fieldId,
          updatedValue: value,
          statusCode: response.status,
        },
      });

      return response.data;
    } catch (error) {
      logAprimoRequestError(
        error,
        'Aprimo update record record field api request failed'
      );
      throw error;
    }
  }
}

export const getRecordById = (recordId: string): Promise<AprimoRecord> =>
  RecordService.getRecordById(recordId);

export const getRecordWithSelectedFields = (
  recordId: string,
  selectFields: string[]
): Promise<AprimoRecord> =>
  RecordService.getRecordWithSelectedFields(recordId, selectFields);

export const updateRecordField = (
  recordId: string,
  fieldId: string,
  value: string
): Promise<AprimoRecord> =>
  RecordService.updateRecordField(recordId, fieldId, value);

export default RecordService;
