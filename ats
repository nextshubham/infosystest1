import axios from 'axios';
import logger from './logger';

const MASKED_VALUE = '***MASKED***';

const sanitizeHeaders = (
  headers: unknown
): Record<string, unknown> | undefined => {
  if (!headers || typeof headers !== 'object') {
    return undefined;
  }

  const headersObject =
    'toJSON' in headers && typeof headers.toJSON === 'function'
      ? (headers.toJSON() as Record<string, unknown>)
      : (headers as Record<string, unknown>);

  return Object.entries(headersObject).reduce<Record<string, unknown>>(
    (sanitizedHeaders, [key, value]) => {
      if (
        key.toLowerCase() === 'authorization' ||
        key.toLowerCase() === 'proxy-authorization'
      ) {
        sanitizedHeaders[key] = MASKED_VALUE;
        return sanitizedHeaders;
      }

      sanitizedHeaders[key] = value;
      return sanitizedHeaders;
    },
    {}
  );
};

export const logAprimoRequestError = (
  error: unknown,
  message: string
): void => {
  if (!axios.isAxiosError(error)) {
    throw error;
  }

  logger.error({
    msg: message,
    options: {
      status: error.response?.status,
      response: JSON.stringify(error.response?.data, null, 2),
      url: error.config?.url,
      headers: sanitizeHeaders(error.config?.headers),
    },
  });
};
