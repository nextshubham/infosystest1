import axios from 'axios';
import logger from '../../utils/logger';
import { logAprimoRequestError } from '../../utils/aprimoErrorLogger';

jest.mock('axios');

jest.mock('../../utils/logger', () => ({
  __esModule: true,
  default: {
    error: jest.fn(),
    info: jest.fn(),
    warn: jest.fn(),
    debug: jest.fn(),
  },
}));

const mockedIsAxiosError = axios.isAxiosError as unknown as jest.MockedFunction<
  typeof axios.isAxiosError
>;

const mockedLoggerError = logger.error as jest.MockedFunction<
  typeof logger.error
>;

describe('aprimoErrorLogger', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  it('should log sanitized Aprimo Axios error', () => {
    mockedIsAxiosError.mockReturnValue(true);

    const error = {
      response: {
        status: 400,
        data: {
          message: 'Bad request',
          token: 'secret-token',
        },
      },
      config: {
        url: '/api/core/record/123',
        method: 'get',
        headers: {
          Authorization: 'Bearer test-token',
          Accept: 'application/json',
        },
        data: 'client_id=test-client&client_secret=test-secret',
      },
    };

    logAprimoRequestError(error, 'Aprimo request failed');

    expect(mockedLoggerError).toHaveBeenCalledWith(
      expect.objectContaining({
        msg: 'Aprimo request failed',
        options: expect.objectContaining({
          status: 400,
          url: '/api/core/record/123',
          method: 'get',
          headers: expect.objectContaining({
            Authorization: '***MASKED***',
            Accept: 'application/json',
          }),
          reqBody: 'client_id=***MASKED***&client_secret=***MASKED***',
        }),
      })
    );
  });

  it('should throw non-Axios error', () => {
    mockedIsAxiosError.mockReturnValue(false);

    const error = new Error('Normal error');

    expect(() => logAprimoRequestError(error, 'Aprimo request failed')).toThrow(
      'Normal error'
    );

    expect(mockedLoggerError).not.toHaveBeenCalled();
  });
});
