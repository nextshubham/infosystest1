import {
  APRIMO_FIELD_IDS,
  SELECT_RECORD_FIELDS,
} from '../constants/aprimo';
import { AssetExpiryWebhookPayload } from '../models/aprimo/WebhookPayload';
import {
  getRecordById,
  getRecordWithSelectedFields,
  updateRecordField,
} from './recordService';
import {
  extractParentRecordIds,
  extractUrrEndDate,
} from '../utils/aprimoRecordUtils';
import { getMinimumDate } from '../utils/dateUtils';
import logger from '../utils/logger';
import IntegrationErrorService from './integrationErrorService';

class AssetWebhookProcessor {
  public static async processAssetWebhook(
    payload: AssetExpiryWebhookPayload
  ): Promise<void> {
    const {
      environment,
      recordId,
      contentType,
      triggerType,
      calculatedExpirationDate,
    } = payload;

    logger.info({
      msg: 'Started processing Asset / non-URR webhook',
      options: {
        recordId,
        contentType,
        triggerType,
        environment,
        calculatedExpirationDate,
      },
    });

    if (!payload.calculatedExpirationDate) {
      logger.warn({
        msg: 'Asset / non-URR webhook payload missing calculatedExpirationDate, continuing with linked URR end dates',
        options: {
          recordId,
          contentType,
          triggerType,
          environment,
        },
      });
    }

    try {
      logger.info({
        msg: 'Fetching Asset / non-URR record from Aprimo',
        options: {
          recordId,
          selectedFields: [
            SELECT_RECORD_FIELDS.URR_LINK_BETWEEN_USAGE_RIGHT_AND_ASSET,
          ],
        },
      });

      const assetRecord = await getRecordWithSelectedFields(payload.recordId, [
        SELECT_RECORD_FIELDS.URR_LINK_BETWEEN_USAGE_RIGHT_AND_ASSET,
      ]);

      logger.info({
        msg: 'Asset / non-URR record retrieved successfully from Aprimo',
        options: {
          recordId: payload.recordId,
        },
      });

      const parentRecordIds = extractParentRecordIds(assetRecord);

      logger.info({
        msg: 'Linked parent Usage Rights Records extracted from asset',
        options: {
          recordId: payload.recordId,
          parentUsageRightRecordCount: parentRecordIds.length,
          parentUsageRightRecordIds: parentRecordIds,
        },
      });

      if (parentRecordIds.length === 0) {
        logger.warn({
          msg: 'No linked parent Usage Rights Records found for asset',
          options: {
            recordId: payload.recordId,
            calculatedExpirationDate: payload.calculatedExpirationDate,
          },
        });
      }

      const urrEndDates = await Promise.all(
        parentRecordIds.map((parentRecordId) =>
          AssetWebhookProcessor.getParentUsageRightEndDate(
            payload.recordId,
            parentRecordId
          )
        )
      );

      logger.info({
        msg: 'Completed extraction of URR end dates for asset',
        options: {
          recordId: payload.recordId,
          calculatedExpirationDate: payload.calculatedExpirationDate,
          urrEndDates,
        },
      });

      const datesToCompare = [
        payload.calculatedExpirationDate,
        ...urrEndDates,
      ].filter((date): date is string => Boolean(date));

      const minimumDate = getMinimumDate(datesToCompare);

      logger.info({
        msg: 'Calculated minimum expiration date for Asset / non-URR record',
        options: {
          recordId: payload.recordId,
          calculatedExpirationDate: payload.calculatedExpirationDate,
          urrEndDates,
          minimumDate,
        },
      });

      if (!minimumDate) {
        logger.warn({
          msg: 'Minimum expiration date not available, skipping asset update',
          options: {
            recordId: payload.recordId,
            calculatedExpirationDate: payload.calculatedExpirationDate,
            urrEndDates,
          },
        });

        return;
      }

      logger.info({
        msg: 'Updating calculated expiration date on Asset / non-URR record',
        options: {
          recordId: payload.recordId,
          fieldId: APRIMO_FIELD_IDS.CU_CALCULATED_EXPIRATION_DATE,
          value: minimumDate,
        },
      });

      await updateRecordField(
        payload.recordId,
        APRIMO_FIELD_IDS.CU_CALCULATED_EXPIRATION_DATE,
        minimumDate
      );

      logger.info({
        msg: 'Calculated expiration date updated successfully on Asset / non-URR record',
        options: {
          recordId: payload.recordId,
          fieldId: APRIMO_FIELD_IDS.CU_CALCULATED_EXPIRATION_DATE,
          updatedValue: minimumDate,
        },
      });

      logger.info({
        msg: 'Completed Asset / non-URR webhook processing',
        options: {
          recordId: payload.recordId,
          contentType: payload.contentType,
          parentUsageRightRecordCount: parentRecordIds.length,
          calculatedExpirationDate: payload.calculatedExpirationDate,
          finalCalculatedExpirationDate: minimumDate,
        },
      });
    } catch (error) {
      logger.error({
        msg: 'Asset / non-URR webhook processing failed',
        options: {
          recordId: payload.recordId,
          contentType: payload.contentType,
          triggerType: payload.triggerType,
          environment: payload.environment,
          calculatedExpirationDate: payload.calculatedExpirationDate,
          error: error instanceof Error ? error.message : String(error),
        },
      });

      if (IntegrationErrorService.isAprimoRelatedError(error)) {
        await IntegrationErrorService.updateIntegrationErrorField(
          payload.recordId,
          error
        );
      }

      throw error;
    }
  }

  private static async getParentUsageRightEndDate(
    assetRecordId: string,
    parentRecordId: string
  ): Promise<string | undefined> {
    logger.info({
      msg: 'Fetching linked parent Usage Rights Record from Aprimo',
      options: {
        assetRecordId,
        urrRecordId: parentRecordId,
      },
    });

    const urrRecord = await getRecordById(parentRecordId);

    logger.info({
      msg: 'Linked parent Usage Rights Record retrieved successfully from Aprimo',
      options: {
        assetRecordId,
        urrRecordId: parentRecordId,
      },
    });

    const urrEndDate = extractUrrEndDate(urrRecord);

    logger.info({
      msg: 'Extracted URR end date from linked parent Usage Rights Record',
      options: {
        assetRecordId,
        urrRecordId: parentRecordId,
        urrEndDate,
      },
    });

    return urrEndDate;
  }
}

export const processAssetWebhook = (
  payload: AssetExpiryWebhookPayload
): Promise<void> => AssetWebhookProcessor.processAssetWebhook(payload);

export default AssetWebhookProcessor;
