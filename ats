import { AprimoContentTypes } from '../constants/aprimoContentTypes';
import { AssetExpiryWebhookPayload } from '../models/aprimo/WebhookPayload';
import { processUsageRightWebhook } from './usageRightWebhookProcessor';
import { processAssetWebhook } from './assetWebhookProcessor';
import logger from '../utils/logger';

class WebhookService {
  public static async processAssetExpiryWebhook(
    payload: AssetExpiryWebhookPayload
  ): Promise<void> {
    const {
      recordId,
      contentType,
      triggerType,
      environment,
      urrEndDate,
      calculatedExpirationDate,
    } = payload;

    logger.info({
      msg: 'Started processing asset expiry webhook',
      options: {
        recordId,
        contentType,
        triggerType,
        environment,
        urrEndDate,
        calculatedExpirationDate,
      },
    });

    try {
      if (!recordId || !contentType) {
        logger.warn({
          msg: 'Invalid asset expiry webhook payload',
          options: {
            recordId,
            contentType,
            triggerType,
            environment,
          },
        });

        throw new Error('recordId and contentType are required in webhook payload');
      }

      if (contentType === AprimoContentTypes.USAGE_RIGHTS_RECORD) {
        logger.debug({
          msg: 'Webhook service content type and record id',
          options: {
            contentType,
            recordId,
          },
        });

        logger.info({
          msg: 'Usage right record flow selected',
          options: {
            recordId,
            contentType,
            triggerType,
            urrEndDate,
          },
        });

        if (!urrEndDate) {
          logger.warn({
            msg: 'Invalid usage rights webhook payload',
            options: {
              recordId,
              contentType,
              urrEndDate,
            },
          });

          throw new Error('urrEndDate is required for usage right record webhook');
        }

        await processUsageRightWebhook(payload);

        logger.info({
          msg: 'Usage right record webhook processing completed',
          options: {
            recordId,
            contentType,
            urrEndDate,
          },
        });

        return;
      }

      logger.info({
        msg: 'Asset or non-URR flow selected',
        options: {
          recordId,
          contentType,
          triggerType,
          calculatedExpirationDate,
        },
      });

      if (!calculatedExpirationDate) {
        logger.warn({
          msg: 'calculatedExpirationDate missing for non-URR webhook, continuing with available linked URR end dates',
          options: {
            recordId,
            contentType,
            triggerType,
            environment,
          },
        });
      }

      await processAssetWebhook(payload);

      logger.info({
        msg: 'Asset or non-URR webhook processing completed',
        options: {
          recordId,
          contentType,
          calculatedExpirationDate,
        },
      });
    } catch (error) {
      logger.error({
        msg: 'Asset expiry webhook processing failed',
        options: {
          recordId,
          contentType,
          triggerType,
          environment,
          urrEndDate,
          calculatedExpirationDate,
          errorMessage: error instanceof Error ? error.message : String(error),
        },
      });

      throw error;
    }
  }
}

export const processAssetExpiryWebhook = (
  payload: AssetExpiryWebhookPayload
): Promise<void> => WebhookService.processAssetExpiryWebhook(payload);

export default WebhookService;
