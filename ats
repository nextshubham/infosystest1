import axios from 'axios';
import logger from './logger';

const MASKED_VALUE = '***MASKED***';

const SENSITIVE_HEADER_NAMES = [
  'authorization',
  'proxy-authorization',
  'cookie',
  'set-cookie',
  'x-api-key',
];

const SENSITIVE_FIELD_NAMES = [
  'client_id',
  'client_secret',
  'access_token',
  'refresh_token',
  'token',
];

type HeadersWithToJson = {
  toJSON: () => Record<string, unknown>;
};

const isRecord = (value: unknown): value is Record<string, unknown> =>
  typeof value === 'object' && value !== null && !Array.isArray(value);

const hasToJson = (value: unknown): value is HeadersWithToJson => {
  if (!isRecord(value)) {
    return false;
  }

  return typeof value.toJSON === 'function';
};

function sanitizeUnknownValue(value: unknown): unknown {
  if (Array.isArray(value)) {
    return value.map(sanitizeUnknownValue);
  }

  if (isRecord(value)) {
    return sanitizeObject(value);
  }

  return value;
}

function sanitizeObject(data: Record<string, unknown>): Record<string, unknown> {
  return Object.entries(data).reduce<Record<string, unknown>>(
    (sanitizedData, [key, value]) => ({
      ...sanitizedData,
      [key]: SENSITIVE_FIELD_NAMES.includes(key.toLowerCase())
        ? MASKED_VALUE
        : sanitizeUnknownValue(value),
    }),
    {}
  );
}

const getHeadersObject = (
  headers: unknown
): Record<string, unknown> | undefined => {
  if (!isRecord(headers)) {
    return undefined;
  }

  if (hasToJson(headers)) {
    return headers.toJSON();
  }

  return headers;
};

const sanitizeHeaders = (
  headers: unknown
): Record<string, unknown> | undefined => {
  const headersObject = getHeadersObject(headers);

  if (!headersObject) {
    return undefined;
  }

  return Object.entries(headersObject).reduce<Record<string, unknown>>(
    (sanitizedHeaders, [key, value]) => ({
      ...sanitizedHeaders,
      [key]: SENSITIVE_HEADER_NAMES.includes(key.toLowerCase())
        ? MASKED_VALUE
        : value,
    }),
    {}
  );
};

const sanitizeStringBody = (data: string): string => {
  try {
    const parsedData = JSON.parse(data) as unknown;
    return JSON.stringify(sanitizeUnknownValue(parsedData));
  } catch {
    const params = new URLSearchParams(data);

    SENSITIVE_FIELD_NAMES.forEach((fieldName) => {
      if (params.has(fieldName)) {
        params.set(fieldName, MASKED_VALUE);
      }
    });

    return params.toString();
  }
};

const sanitizeRequestBody = (data: unknown): unknown => {
  if (!data) {
    return undefined;
  }

  if (typeof data === 'string') {
    return sanitizeStringBody(data);
  }

  return sanitizeUnknownValue(data);
};

export const logAprimoRequestError = (
  error: unknown,
  message: string
): void => {
  if (axios.isAxiosError(error)) {
    logger.error({
      msg: message,
      options: {
        status: error.response?.status,
        response: sanitizeUnknownValue(error.response?.data),
        url: error.config?.url,
        method: error.config?.method,
        headers: sanitizeHeaders(error.config?.headers),
        reqBody: sanitizeRequestBody(error.config?.data),
      },
    });

    return;
  }

  logger.error({
    msg: message,
    options: {
      error: error instanceof Error ? error.message : String(error),
    },
  });
};
