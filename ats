private static sanitizeTokenRequestBody(data: unknown): string | undefined {
  if (!data) {
    return undefined;
  }

  const requestBody = data.toString();

  const params = new URLSearchParams(requestBody);

  const sensitiveFields = ['client_id', 'client_secret', 'access_token', 'token'];

  sensitiveFields.forEach((field) => {
    if (params.has(field)) {
      params.set(field, '***MASKED***');
    }
  });

  return params.toString();
}
